# Required: Gemini API key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=gemini_api_key_here

# Optional: Inception Labs Mercury 2 API key (get one at https://platform.inceptionlabs.ai)
INCEPTION_API_KEY=your_inception_api_key_here

# Synthesis provider: gemini (default) or mercury
SYNTHESIS_PROVIDER=mercury

# OpenAlex polite pool email (faster rate limits — server-side, not exposed to callers)
OPENALEX_EMAIL=your@email.com

# Server port (default: 3000)
PORT=3333
